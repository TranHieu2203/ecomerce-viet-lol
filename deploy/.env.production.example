# Mẫu tham chiếu — nội dung tương tự deploy/.env.production trong repo (domain quatangtaya.com / admin.quatangtaya.com).
# Trên server: đổi POSTGRES_PASSWORD tay (volume DB). JWT/COOKIE/REVALIDATE: init server có thể tự sinh nếu vẫn CHANGE_ME_*.
# Sau init: NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY thường được ghi tự từ seed; nếu không, copy pk_ trong Admin.

# --- DockerHub images (build ở local, server chỉ pull) ---
# Ví dụ:
#   DOCKERHUB_NAMESPACE=tran... (DockerHub username/org)
#   BACKEND_IMAGE=tran.../ecomerce-viet-lol-backend:prod-2026-04-10
#   STOREFRONT_IMAGE=tran.../ecomerce-viet-lol-storefront:prod-2026-04-10
DOCKERHUB_NAMESPACE=hieutech2203
BACKEND_IMAGE=hieutech2203/ecomerce-viet-lol-backend:prod
STOREFRONT_IMAGE=hieutech2203/ecomerce-viet-lol-storefront:prod

POSTGRES_USER=medusa
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_STRONG
POSTGRES_DB=medusa

# Nếu POSTGRES_PASSWORD có ký tự đặc biệt (vd: '@'), hãy set DATABASE_URL với password đã URL-encode.
# Ví dụ: mật khẩu "abc@123" -> "abc%40123"
# DATABASE_URL=postgres://medusa:abc%40123@postgres:5432/medusa?ssl=false

STORE_CORS=https://quatangtaya.com,https://www.quatangtaya.com
ADMIN_CORS=https://admin.quatangtaya.com
AUTH_CORS=https://quatangtaya.com,https://www.quatangtaya.com,https://admin.quatangtaya.com

JWT_SECRET=CHANGE_ME_JWT_SECRET_LONG_RANDOM
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET_LONG_RANDOM

STOREFRONT_REVALIDATE_URL=http://storefront:8000
REVALIDATE_SECRET=CHANGE_ME_REVALIDATE_SAME_AS_STOREFRONT

# CMS_PREVIEW_SECRET=

NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_CHANGE_ME_AFTER_ADMIN
MEDUSA_BACKEND_URL=https://admin.quatangtaya.com
NEXT_PUBLIC_DEFAULT_REGION=vn
