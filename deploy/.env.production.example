# Sao chép thành deploy/.env.production và chỉnh giá trị (file .env.production không commit).

# --- PostgreSQL (mật khẩu mạnh; nếu có ký tự đặc biệt cần URL-encode trong DATABASE_URL — compose đã ghép sẵn) ---
POSTGRES_USER=medusa
POSTGRES_PASSWORD=thay-bang-mat-khau-manh
POSTGRES_DB=medusa

# --- Medusa HTTP / CORS (domain thật) ---
STORE_CORS=https://quatangtaya.com,https://www.quatangtaya.com
ADMIN_CORS=https://admin.quatangtaya.com
AUTH_CORS=https://quatangtaya.com,https://www.quatangtaya.com,https://admin.quatangtaya.com

JWT_SECRET=thay-bang-chuoi-dai-ngau-nhien
COOKIE_SECRET=thay-bang-chuoi-dai-khac

# ISR: backend gọi vào container storefront (mạng Docker)
STOREFRONT_REVALIDATE_URL=http://storefront:8000
REVALIDATE_SECRET=thay-cung-gia-tri-trong-storefront

# Tuỳ chọn preview CMS
# CMS_PREVIEW_SECRET=

# --- Storefront build + runtime (URL công khai HTTPS tới Medusa qua NPM) ---
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_thay_sau_khi_tao_trong_admin
MEDUSA_BACKEND_URL=https://admin.quatangtaya.com
NEXT_PUBLIC_DEFAULT_REGION=vn
