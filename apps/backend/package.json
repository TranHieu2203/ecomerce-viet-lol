{
  "name": "backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "node ./node_modules/@medusajs/cli/cli.js build",
    "seed": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/seed.ts",
    "seed:ensure-admin-user": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/seed-ensure-admin-user.ts",
    "seed:ensure-shipping": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/ensure-shipping-readiness.ts",
    "seed:appendix": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/seed-appendix-only.ts",
    "seed:sales-kit": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/seed-sales-kit.ts",
    "seed:sales-kit:confirm": "cross-env SEED_SALES_KIT_ALLOW=1 node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/seed-sales-kit.ts",
    "start": "node ./node_modules/@medusajs/cli/cli.js start",
    "dev": "node ./node_modules/@medusajs/cli/cli.js develop",
    "test:integration:http": "cross-env TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "cross-env TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "cross-env TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "typecheck:admin": "tsc --noEmit -p src/admin/tsconfig.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/cli": "2.13.1",
    "@medusajs/framework": "2.13.1",
    "@medusajs/medusa": "2.13.1",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/extension-text-align": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "sharp": "^0.33.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.1",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2"
}
