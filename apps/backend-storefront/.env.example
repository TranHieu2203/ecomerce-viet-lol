# Copy to .env.local — không commit file chứa secret thật.
# README: mục "Mặc định VN / VND (FR-2b)".

MEDUSA_BACKEND_URL=http://localhost:9000

# Lấy sau khi chạy seed backend (Sales Channel → Publishable API Key)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_after_seed

NEXT_PUBLIC_BASE_URL=http://localhost:8000

# FR-2b: ISO-2 country → chọn Medusa region (seed: Vietnam + currency vnd). Phải khớp region có country vn.
NEXT_PUBLIC_DEFAULT_REGION=vn

# Đồng bộ với REVALIDATE_SECRET trong apps/backend/.env (ISR sau CMS)
REVALIDATE_SECRET=change-me-revalidate

# Tuỳ chọn
# NEXT_PUBLIC_STORE_DISPLAY_NAME=
# Bật (true / 1 / yes, không phân biệt hoa thường) để hiện dòng "Powered by Medusa & Next" ở footer/checkout khi build production (mặc định chỉ hiện khi NODE_ENV !== production).
# NEXT_PUBLIC_SHOW_DEV_BRANDING=
# NEXT_PUBLIC_STRIPE_KEY=
