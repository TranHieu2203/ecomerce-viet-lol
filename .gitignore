node_modules/

# CommonJS script cục bộ / deploy helper (không theo dõi trong git)
*.cjs

# SSH shell thang VPS (neu ban dat IP that trong file — co the ignore)
ssh-root-server.bat

.env
.env.local
apps/*/.env
!apps/*/.env.template
!apps/*/.env.test

# Production env
# NOTE: Repo có sẵn `deploy/.env.production` dạng template (CHANGE_ME_*).
# Không commit file env thật có secrets ngoài đời.
deploy/.env.production.local
.DS_Store
*.log
.next/
apps/backend/.medusa/

# Medusa file module: upload local (không commit)
apps/backend/static/**
!apps/backend/static/.gitkeep

# Dev tooling artifacts (không cần trên prod)
_bmad/
_bmad-output/

# Ảnh sản phẩm Sales Kit (quản lý ngoài git)
docs/

# Windows-only scripts
*.bat
*.ps1
