# Mẫu biến cho Medusa backend (copy sang apps/backend/.env)
# PostgreSQL từ docker-compose — cổng 5433 tránh xung đột Postgres trên Windows

DATABASE_URL=postgres://medusa:medusa@localhost:5433/medusa
REDIS_URL=redis://localhost:6379

STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

JWT_SECRET=change-me
COOKIE_SECRET=change-me

# ISR: backend gọi để làm mới cache storefront sau khi lưu CMS (Epic 3.5)
STOREFRONT_REVALIDATE_URL=http://localhost:8000
REVALIDATE_SECRET=change-me-revalidate

# Seed Sales Kit: script xóa toàn bộ sản phẩm/collection/CMS rồi seed lại từ docs/ — bắt buộc xác nhận.
# Cách 1: đặt SEED_SALES_KIT_ALLOW=1 trong apps/backend/.env
# Cách 2: chạy npm run seed:sales-kit:confirm từ apps/backend
# SEED_SALES_KIT_ALLOW=1

# Xem trước bản nháp CMS (Story 9.2): HMAC ký token; bắt buộc nếu dùng POST /admin/custom/cms-preview-token
CMS_PREVIEW_SECRET=change-me-cms-preview

# --- Storefront: copy sang apps/backend-storefront/.env.local (hoặc dùng apps/backend-storefront/.env.example) ---
# FR-2b / SC-1b: seed backend tạo region Vietnam (country vn) + VND; biến dưới map ISO-2 → Medusa region trong getRegion() (xem regions.ts).
# i18n URL: chỉ vi + en (/vi, /en); NEXT_PUBLIC_DEFAULT_REGION không phải mã locale mà là quốc gia Medusa.
MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_after_seed
NEXT_PUBLIC_DEFAULT_REGION=vn
REVALIDATE_SECRET=change-me-revalidate
# Tuỳ chọn: URL public storefront; tên hiển thị fallback khi chưa có CMS
# NEXT_PUBLIC_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_STORE_DISPLAY_NAME=My Store
